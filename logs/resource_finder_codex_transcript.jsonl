{"type":"item.started","item":{"id":"item_59","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\nroot = Path('datasets')\nconfigs = [\n    ('mnist', 'mnist'),\n    ('fashion_mnist', 'fashion_mnist'),\n    ('cifar10', 'cifar10'),\n]\nsummary = {}\nfor name, out in configs:\n    ds = load_dataset(name)\n    outdir = root / out\n    ds.save_to_disk(str(outdir))\n    sample_dir = outdir / 'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    split = 'train' if 'train' in ds else list(ds.keys())[0]\n    rows = []\n    for ex in ds[split].select(range(min(5, len(ds[split])))):\n        row = {k: (str(v) if k == 'image' else v) for k, v in ex.items() if k \"'!= '\"'image'}\n        if 'image' in ex:\n            row['image_size'] = list(ex['image'].size)\n            row['image_mode'] = ex['image'].mode\n        rows.append(row)\n    (sample_dir / 'samples.json').write_text(json.dumps(rows, indent=2), encoding='utf-8')\n    summary[name] = {split_name: len(split_ds) for split_name, split_ds in ds.items()}\nprint(json.dumps(summary, indent=2))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
